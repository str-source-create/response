# Server
PORT=3000

# Neon Postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Hostaway API credentials
HOSTAWAY_BASE_URL=https://api.hostaway.com
HOSTAWAY_CLIENT_ID=your_hostaway_client_id
HOSTAWAY_CLIENT_SECRET=your_hostaway_client_secret

# Optional path overrides
HOSTAWAY_TOKEN_PATH=/v1/accessTokens
HOSTAWAY_LISTINGS_PATH=/v1/listings
HOSTAWAY_RESERVATIONS_PATH=/v1/reservations
HOSTAWAY_CONVERSATIONS_PATH=/v1/conversations
HOSTAWAY_MESSAGES_PATH=/v1/messages
