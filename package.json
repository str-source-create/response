{
  "name": "hostaway-neon-sync",
  "version": "1.0.0",
  "description": "Local Hostaway to Neon sync tool with CSV exports and UI",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "hostaway",
    "neon",
    "postgres",
    "express",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
